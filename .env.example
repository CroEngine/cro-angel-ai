# Environment variables — copy to `.env` and fill in. `.env` is gitignored;
# this template (no secret values) is the committed reference.

# ── Supabase (app database / auth) ───────────────────────────────────────────
# Publishable/anon + URL + project ref are PUBLIC by design (shipped to the
# browser via the VITE_ vars at build time). Safe to share; not real secrets.
SUPABASE_URL=
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Browserbase (corpus freeze / live capture) ───────────────────────────────
# REAL SECRET — server-side only. Used by the freeze pipeline:
#   bun run freeze            (scripts/freeze-site.ts)
#   bun run angel             (scripts/angel-report.ts)
#   bun run scripts/promote-corpus.ts
# NOT used by CI (it replays the committed frozen .mhtml captures) and NOT a
# Supabase/GitHub concern — it's read from this process's env (process.env).
# Get both from the Browserbase dashboard → Settings / API Keys.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
