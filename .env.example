# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for cro-angel-ai — TEMPLATE (no real values here).
# Copy what you need into the right store for HOW you run the code. See SECRETS.md.
#
#   • Local dev .......... copy to .env.local  (gitignored; `bun run` auto-loads)
#   • Claude Code web .... paste into the environment's "Environment variables"
#                          field — the ONLY option there, and it's VISIBLE; rotate
#   • Deployed Worker .... `wrangler secret put NAME`  (.dev.vars for local wrangler)
#
# NEVER put a SECRET in the tracked .env, and never behind a VITE_ name
# (VITE_ values are bundled into the browser).
# ─────────────────────────────────────────────────────────────────────────────

# ===== SECRETS — never commit; set in your runtime's secret store ============

# Claude API key — the Angel advisory layer (src/lib/tests/angel.server.ts)
ANTHROPIC_API_KEY=

# Browserbase API key — the freeze pipeline
#   (browserbase.server.ts, engine.server.ts, snapshot/freeze.server.ts)
BROWSERBASE_API_KEY=

# Supabase service-role key — server-only admin client; BYPASSES row-level
# security (src/integrations/supabase/client.server.ts). Highly sensitive.
SUPABASE_SERVICE_ROLE_KEY=

# Google PageSpeed key — OPTIONAL (src/lib/tests/pagespeed.functions.ts)
GOOGLE_PAGESPEED_API_KEY=

# ===== PUBLIC config — safe to commit / safe in the visible env field ========

# Browserbase project id — an identifier, NOT a secret
BROWSERBASE_PROJECT_ID=

# Supabase public endpoint + anon/"publishable" key (JWT role: anon; RLS-guarded,
# meant to ship to the browser). The VITE_-prefixed copies are bundled into the
# client. These are the values that already live in the committed .env.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ===== OPTIONAL (public / operational) =======================================

# Asset-rewrite base used when externalizing frozen assets
# (src/lib/tests/snapshot/externalize.server.ts)
LOVABLE_ASSETS_BASE_URL=

# Local replay Chromium path for the snapshot harness — local-only convenience
# (src/lib/tests/snapshot/harness.server.ts)
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
