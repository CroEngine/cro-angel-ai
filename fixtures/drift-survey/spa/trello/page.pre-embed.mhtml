:root { font-size: 16px; }

body { font-family: var(--font-family-text, 'Charlie Text', sans-serif); fo=
nt-size: 1.25rem; min-height: 100vh; }

body.prevent-scroll { overflow: hidden; }

.app-root { min-height: 100vh; display: flex; flex-direction: column; }

.app-root > div, .app-root > header, .app-root > main, .app-root > footer {=
 width: 100%; }

.app-root > :not(main) { flex-grow: 0; flex-shrink: 0; }

.app-root > main { flex-grow: 1; }

html[lang=3D"vi"] body { }

h1, .h1 { font-family: var(--font-family-display, 'Charlie Display', sans-s=
erif); font-weight: 500; margin-block: 0px 0.5rem; font-size: 2rem; line-he=
ight: 1.25; }

@media (min-width: 768px) {
  h1, .h1 { font-size: 2.75rem; line-height: 1.18182; }
}

@media (min-width: 992px) {
  h1, .h1 { font-size: 3rem; line-height: 1.25; }
}

h2, .h2 { font-family: var(--font-family-display, 'Charlie Display', sans-s=
erif); font-weight: 500; margin-block: 0px 0.5rem; font-size: 1.5rem; line-=
height: 1.33333; }

@media (min-width: 768px) {
  h2, .h2 { font-size: 2.25rem; line-height: 1.33333; }
}

h3, .h3 { font-family: var(--font-family-display, 'Charlie Display', sans-s=
erif); font-weight: 500; margin-block: 0px 0.5rem; font-size: 1.25rem; line=
-height: 1.2; }

@media (min-width: 768px) {
  h3, .h3 { font-size: 1.5rem; line-height: 1.33333; }
}

h4, .h4 { font-family: var(--font-family-display, 'Charlie Display', sans-s=
erif); font-weight: 500; margin-block: 0px 0.5rem; font-size: 1rem; line-he=
ight: 1.25; }

@media (min-width: 768px) {
  h4, .h4 { font-size: 1.25rem; line-height: 1.2; }
}

h5, .h5 { font-family: var(--font-family-display, 'Charlie Display', sans-s=
erif); font-weight: 500; margin-block: 0px 0.5rem; font-size: 1rem; line-he=
ight: 1.25; text-transform: uppercase; }

h6, .h6 { font-size: 1rem; font-weight: 500; line-height: 1.2; margin-block=
: 0px 0.5rem; }

p { margin-block-end: 1.5rem; }

ul, ol { margin-block: 0.5rem 1rem; padding-inline-start: 1.5rem; }

li { margin-block-end: 0.25rem; }

li:last-child { margin-block-end: 0px; }

img { max-width: 100%; height: auto; }

a { color: rgb(0, 82, 204); text-decoration: none; }

a:hover { text-decoration: underline !important; }

main [style*=3D"background-color: rgb(255, 255, 255)"] a, main [style*=3D"b=
ackground-color: rgb(244, 245, 247)"] a, main [data-testid=3D"block"] a { c=
olor: rgb(0, 82, 204) !important; }

header a, header button { color: inherit; }

.tooltip-content a { color: rgb(255, 255, 255); }

.tooltip-content p { margin-block-end: 0.5rem; }

.tooltip-content p:last-child { margin-block-end: 0px; }

.grecaptcha-badge { visibility: hidden; }
