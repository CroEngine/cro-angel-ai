rder-radius: 9999px; border-style: none; background-color: rgba(146, 148, 1=
51, 0.65); }

.nuka-page-indicator.nuka-page-indicator-active, .nuka-page-indicator.nuka-=
page-indicator-active:hover { background-color: rgb(229, 231, 235); }

.nuka-page-indicator:hover { background-color: rgb(229, 231, 235); }
