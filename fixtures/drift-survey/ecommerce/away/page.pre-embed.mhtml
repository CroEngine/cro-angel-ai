t: 0px; z-index: 999999; margin-top: 4px; width: max-content; min-width: 10=
0%; background-color: rgb(255, 255, 255); border: 1px solid rgb(208, 208, 2=
08); border-radius: 4px; box-shadow: rgba(0, 0, 0, 0.15) 0px 3px 8px; max-h=
eight: 300px; overflow-y: auto; }

.bb-custom-select-container.bb-is-open .bb-custom-select-panel { display: b=
lock; }

