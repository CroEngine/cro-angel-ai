@keyframes fadeIn {=20
  100% { opacity: 1; }
}

@keyframes fadeOut {=20
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(0.95); }
}

@keyframes overlayContentShow {=20
  0% { opacity: 0; transform: translateY(-2%) scale(1); }
  100% { opacity: 1; transform: translate(0px) scale(1); }
}

@keyframes overlayContentHide {=20
  0% { opacity: 1; transform: translate(0px) scale(1); }
  100% { opacity: 0; transform: translateY(-2%) scale(1); }
}

@keyframes dropdownFadeIn {=20
  0% { opacity: 0; transform: scale(0.95); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes dropdownFadeOut {=20
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(0.95); }
}

@keyframes fadeInOverlayBg {=20
  0% { opacity: 0; }
  100% { opacity: 0.75; }
}

@keyframes fadeOutOverlayBg {=20
  0% { opacity: 0.75; }
  100% { opacity: 0; }
}

@keyframes slideDown {=20
  0% { opacity: 0; height: 0px; }
  100% { height: var(--radix-accordion-content-height); opacity: 1; }
}

@keyframes slideUp {=20
  0% { height: var(--radix-accordion-content-height); opacity: 1; }
  100% { opacity: 0; height: 0px; }
}

@keyframes slideDownNormal {=20
  0% { opacity: 0; height: 0px; }
  100% { height: inherit; opacity: 1; }
}

@keyframes slideUpNormal {=20
  0% { height: inherit; opacity: 1; }
  100% { opacity: 0; height: 0px; }
}

@keyframes panelSlideLeftOut {=20
  0% { opacity: 0; transform: translate(-100%); }
  100% { opacity: 1; transform: translate(0px); }
}

@keyframes panelSlideLeftIn {=20
  0% { opacity: 1; transform: translate(0px); }
  100% { opacity: 0; transform: translate(-100%); }
}

@keyframes panelSlideRightOut {=20
  0% { opacity: 0; transform: translate(100%); }
