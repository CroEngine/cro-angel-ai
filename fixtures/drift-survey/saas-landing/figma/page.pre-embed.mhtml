.bb-custom-select-container.bb-is-disabled .bb-custom-select-opener { backg=
round-color: rgb(233, 236, 239); border-color: rgb(80, 80, 80); color: rgb(=
108, 117, 125); cursor: not-allowed; }

.bb-custom-select-container.bb-is-disabled { cursor: not-allowed; }

.bb-custom-select-container.bb-is-disabled select { cursor: not-allowed; }

.bb-custom-select-container.bb-is-disabled .bb-custom-select-opener::after =
{ border-top-color: rgb(108, 117, 125); }

.bb-custom-select-opener::after { content: ""; position: absolute; right: 8=
px; top: 50%; transform: translateY(-50%); width: 0px; height: 0px; border-=
left: 5px solid transparent; border-right: 5px solid transparent; border-to=
p: 5px solid rgb(102, 102, 102); }

