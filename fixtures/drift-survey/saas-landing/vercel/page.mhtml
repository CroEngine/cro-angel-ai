  0% { opacity: 0; transform: translateY(5px); }
  100% { opacity: 1; transform: none; }
}

@keyframes feedbackFadeIn { 
  0% { opacity: 0; scale: 0.95; }
  100% { opacity: 1; scale: 1; }
}

@keyframes feedbackFadeOut { 
  0% { opacity: 1; scale: 1; }
  100% { opacity: 0; scale: 0.95; }
}

@keyframes fadeOut { 
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes cmdkLoading { 
  0% { opacity: 1; transform: translate(-100%); }
  100% { opacity: 1; transform: translate(300%); }
}

@keyframes cmdkFadeIn { 
  0% { opacity: 0; }
  100% { opacity: 0.8; }
}

@keyframes cmdkFadeOut { 
  0% { opacity: 0.8; }
  100% { opacity: 0; }
}

@keyframes cmdkScaleIn { 
  0% { transform: scale(var(--ds-motion-overlay-scale)); opacity: 0; }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes cmdkScaleOut { 
  0% { opacity: 1; transform: scale(1); }
  100% { transform: scale(var(--ds-motion-overlay-scale)); opacity: 0; }
}
