@keyframes spin { 
  100% { transform: rotate(360deg); }
}

@keyframes ping { 
  75%, 100% { opacity: 0; transform: scale(2); }
}

@keyframes pulse { 
  50% { opacity: 0.5; }
}

@keyframes bounce { 
  0%, 100% { animation-timing-function: cubic-bezier(0.8, 0, 1, 1); transfo=
rm: translateY(-25%); }
  50% { animation-timing-function: cubic-bezier(0, 0, 0.2, 1); transform: n=
