px; top: 50%; transform: translateY(-50%); width: 0px; height: 0px; border-=
left: 5px solid transparent; border-right: 5px solid transparent; border-to=
p: 5px solid rgb(102, 102, 102); }

.bb-custom-select-opener.bb-is-open::after { transform: translateY(-50%) ro=
tate(180deg); }

.bb-customSelect select { position: relative; width: 100%; }

.bb-custom-select-panel { display: none; position: absolute; top: 100%; lef=
t: 0px; z-index: 999999; margin-top: 4px; width: max-content; min-width: 10=
0%; background-color: rgb(255, 255, 255); border: 1px solid rgb(208, 208, 2=
08); border-radius: 4px; box-shadow: rgba(0, 0, 0, 0.15) 0px 3px 8px; max-h=
eight: 300px; overflow-y: auto; }

.bb-custom-select-container.bb-is-open .bb-custom-select-panel { display: b=
lock; }

.bb-custom-select-option { padding: 6px 12px; line-height: 1.5; cursor: poi=
nter; white-space: nowrap; }

.bb-custom-select-option:hover, .bb-custom-select-option.bb-has-focus { bac=
kground-color: rgb(240, 249, 250); }

.bb-custom-select-option.bb-is-selected { background-color: rgb(233, 236, 2=
39); }
